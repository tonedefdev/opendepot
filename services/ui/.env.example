# Base URL for the OpenDepot server API, as seen from the Next.js server-side
# runtime. In production this is the NGINX upstream server service address.
# Example: http://server.opendepot-system.svc.cluster.local
OPENDEPOT_SERVER_URL=http://localhost:8080

# Public runtime URL of this UI service — used to construct OIDC callback redirect URIs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OIDC issuer URL (Dex or compatible provider).
OIDC_ISSUER_URL=http://localhost:5556/dex

# OIDC client ID for the UI (separate from the tofu login client).
OIDC_CLIENT_ID=opendepot-ui

# OIDC client secret (for confidential client mode).
OIDC_CLIENT_SECRET=change-me

# Space-separated OIDC scopes to request.
OIDC_SCOPES=openid profile email groups

# Callback path registered with the OIDC provider.
OIDC_CALLBACK_PATH=/auth/callback

# Session password — must be at least 32 characters.
SESSION_PASSWORD=change-me-to-a-32-char-or-longer-secret

# Set to "true" to show a developer token input field in the UI.
# Must be false (unset) in production.
DEV_TOKEN_INPUT_ENABLED=false
